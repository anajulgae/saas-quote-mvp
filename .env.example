# =============================================================================
# FlowBill MVP — 환경 변수 예시 (.env.local 에 복사해 사용)
# =============================================================================

NEXT_PUBLIC_APP_NAME=FlowBill AI

# --- Supabase (비공개 베타·프로덕션에서 필수) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 이메일 인증·비밀번호 재설정 링크의 도메인 (끝 슬래시 없음).
# Vercel Production 권장: https://www.bill-io.com (또는 비워 두면 동일 기본값이 코드에 적용됨, site-url.ts)
# 로컬 개발: 비워 두면 localhost:3000 — 여기에 프로덕션 URL을 넣지 마세요(리다이렉트가 운영으로 감).
NEXT_PUBLIC_SITE_URL=

# Search Console HTML 태그 인증용(값이 있을 때만 layout 메타에 삽입됨)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Supabase Dashboard → Authentication → URL Configuration
# - Site URL: 배포 기본 URL (예: https://app.example.com)
# - Redirect URLs 예시 (실제 도메인에 맞게):
#     {NEXT_PUBLIC_SITE_URL}/auth/callback      ← 가입·이메일 인증 PKCE
#     {NEXT_PUBLIC_SITE_URL}/reset-password     ← 비밀번호 재설정 메일 링크
#     http://localhost:3000/auth/callback
#     http://localhost:3000/reset-password
#
# 흐름: /forgot-password → 메일 → /reset-password?code=… → 새 비밀번호 저장 → /login?reset=success

# ⚠️ 절대 하지 말 것:
# - service_role 키( Service Role secret )를 여기 넣거나 NEXT_PUBLIC_* 로 노출하지 마세요.
# - service_role 은 RLS를 우회합니다. 클라이언트/브라우저에는 anon 키만 사용합니다.
# - 앱 런타임은 anon 만 사용합니다. 로컬에서만 아래처럼 일회성 시드 스크립트에 service_role 을 둘 수 있습니다.
#
# 로컬 전용 (npm run seed:test-customers):
# SUPABASE_SERVICE_ROLE_KEY=
# SEED_TARGET_USER_EMAIL=   # 또는 SEED_TARGET_USER_ID= (Auth 사용자가 여러 명일 때 필수)

# --- 카카오 알림톡 BYOA (추가 환경변수 없음) ---
# 설정 화면 → 「메시지 채널 연결」에서 HTTPS 프록시 URL·키·템플릿을 저장합니다.
# Bill-IO는 JSON 페이로드만 POST 하며, 실제 Solapi/NHN 등 API 호출은 사용자 프록시에서 수행합니다.

# --- 전자세금계산서 ASP (별도 ENV 불필요) ---
# 설정 화면 → 「전자세금계산서 ASP 연동」에서 제공사·API 키 등을 DB에 저장합니다.
# Bill-IO가 대신 과금하는 발행 서비스가 아니라, 사용자 BYOA 계정으로 청구 화면에서 발행 요청을 보냅니다.
# 페이로드 형식: src/lib/server/messaging/user-endpoint.ts (BillIoMessagingPayloadV1)

# --- Resend (견적·청구서 이메일 발송 — 운영에서 사실상 필수) ---
# 대시보드: https://resend.com — API Keys 에서 발급
RESEND_API_KEY=
# 인증된 도메인의 발신 주소(권장). 예: "Bill-IO <mail@yourdomain.com>"
# 미설정 시 설정 화면 이메일 또는 Resend 테스트 주소로 시도(403/422 시 도메인 인증 필요)
RESEND_FROM=
# 공개 문의 폼 → 운영자 알림 메일 발신(선택, 없으면 RESEND_FROM 사용)
# RESEND_FROM_EMAIL=

# --- Supabase service role (선택: 공개 문의 후 운영자 이메일에서 notification_preferences 조회) ---
# 미설정 시 이메일 알림은 건너뜁니다. 클라이언트에 절대 넣지 마세요.
# SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (기능별 모델 분리 — 하드코딩 없음, 아래 전부 운영에서 설정) ---
OPENAI_API_KEY=
# /api/ai/inquiry-structure — 짧은 구조화·분류 (저비용)
OPENAI_MODEL_INQUIRY_STRUCTURE=gpt-5.4-nano
# /api/ai/inquiry-analyze — 문의 트리아지·다음 액션 (저비용, 미설정 시 OPENAI_MODEL)
OPENAI_MODEL_INQUIRY_ANALYZE=gpt-5.4-nano
# /api/ai/collection-advice — 청구 추심·리마인드 추천 (저비용, 미설정 시 OPENAI_MODEL)
OPENAI_MODEL_COLLECTION_ADVICE=gpt-5.4-nano
# /api/ai/compose-message — 발송·리마인드 문구 (저비용)
OPENAI_MODEL_COMPOSE_MESSAGE=gpt-5.4-nano
# /api/ai/quote-draft — 견적 초안 (품질 우선)
OPENAI_MODEL_QUOTE_DRAFT=gpt-5.4-mini
# 설정 → 업체 소개 페이지 → AI 초안 (Pro 전용 서버 액션, 미설정 시 OPENAI_MODEL 사용)
OPENAI_MODEL_LANDING_DRAFT=gpt-5.4-mini
# quote-draft 주 모델 실패 시 1회 재시도용 (OPENAI_QUOTE_DRAFT_FALLBACK=true 일 때만)
OPENAI_MODEL_FALLBACK=gpt-5.4-nano
# 기본 끔. 켜면 mini 실패 시 FALLBACK 모델로 한 번 더 호출(비용 2배 가능)
# OPENAI_QUOTE_DRAFT_FALLBACK=true
# 출력 상한(미설정 시 코드 기본: inquiry 500 / message 600 / quote 1400)
# OPENAI_MAX_OUTPUT_TOKENS_INQUIRY=500
# OPENAI_MAX_OUTPUT_TOKENS_INQUIRY_ANALYZE=900
# OPENAI_MAX_OUTPUT_TOKENS_COLLECTION_ADVICE=900
# OPENAI_MAX_OUTPUT_TOKENS_MESSAGE=600
# OPENAI_MAX_OUTPUT_TOKENS_QUOTE=1400
# OPENAI_MAX_OUTPUT_TOKENS_LANDING=1800
# AI HTTP 타임아웃(ms). 기본 55000
# OPENAI_TIMEOUT_MS=55000

# --- 공개 문의 이메일 (랜딩 /billing Business 블록) ---
# NEXT_PUBLIC_CONTACT_EMAIL=

# --- 고객센터 (/help 헤더 등에 노출되는 지원 메일, 없으면 메일 버튼 숨김) ---
# NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# --- 데모 로그인 (선택) ---
# ENABLE_DEMO_LOGIN 동작 요약:
#   - "true" / "1"  → 어떤 NODE_ENV 에서도 데모 로그인·데모 쿠키 인정 (Supabase 설정 여부와 무관)
#   - "false" / "0" → 어떤 NODE_ENV 에서도 데모 비활성
#   - 미설정        → production 에서만 데모 끔 / 그 외(로컬 등)에서는 데모 허용
#
# 프로덕션(Vercel Production) 기본: 데모 비활성.
# 외부 점검용 공개 데모: docs/public-demo.md 참고. 켤 때 DEMO_LOGIN_PASSWORD 는 16자 이상 필수.
ENABLE_DEMO_LOGIN=

# 데모 전용(운영 계정과 다르게). 이 이메일로 Supabase Auth 사용자를 만들지 마세요.
DEMO_LOGIN_EMAIL=demo-review@flowbill.kr
# 로컬: 짧은 값 허용. 프로덕션: 16자 이상 강한 비밀번호 필수 (openssl rand -base64 24 등).
DEMO_LOGIN_PASSWORD=
