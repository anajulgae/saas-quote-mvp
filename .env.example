# =============================================================================
# FlowBill MVP — 환경 변수 예시 (.env.local 에 복사해 사용)
# =============================================================================

NEXT_PUBLIC_APP_NAME=FlowBill AI

# --- Supabase (비공개 베타·프로덕션에서 필수) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 이메일 인증·비밀번호 재설정 링크의 도메인 (Vercel 프로덕션에서는 사실상 필수).
# 예: https://www.bill-io.com (끝 슬래시 없음)
# 비워 두면 Vercel은 VERCEL_URL(배포마다 다른 *.vercel.app)을 쓸 수 있어, Supabase Redirect URLs 과
# 안 맞으면 재설정 링크가 Site URL 루트(/)로만 열리고 로그인으로 튕깁니다.
NEXT_PUBLIC_SITE_URL=

# Supabase Dashboard → Authentication → URL Configuration
# - Site URL: 배포 기본 URL (예: https://app.example.com)
# - Redirect URLs 예시 (실제 도메인에 맞게):
#     {NEXT_PUBLIC_SITE_URL}/auth/callback      ← 가입·이메일 인증 PKCE
#     {NEXT_PUBLIC_SITE_URL}/reset-password     ← 비밀번호 재설정 메일 링크
#     http://localhost:3000/auth/callback
#     http://localhost:3000/reset-password
#
# 흐름: /forgot-password → 메일 → /reset-password?code=… → 새 비밀번호 저장 → /login?reset=success

# ⚠️ 절대 하지 말 것:
# - service_role 키( Service Role secret )를 여기 넣거나 NEXT_PUBLIC_* 로 노출하지 마세요.
# - service_role 은 RLS를 우회합니다. 클라이언트/브라우저에는 anon 키만 사용합니다.
# - 앱 런타임은 anon 만 사용합니다. 로컬에서만 아래처럼 일회성 시드 스크립트에 service_role 을 둘 수 있습니다.
#
# 로컬 전용 (npm run seed:test-customers):
# SUPABASE_SERVICE_ROLE_KEY=
# SEED_TARGET_USER_EMAIL=   # 또는 SEED_TARGET_USER_ID= (Auth 사용자가 여러 명일 때 필수)

# --- Resend (견적서 이메일 발송 — 운영에서 사실상 필수) ---
# 대시보드: https://resend.com — API Keys 에서 발급
RESEND_API_KEY=
# 인증된 도메인의 발신 주소(권장). 예: "Bill-IO <mail@yourdomain.com>"
# 미설정 시 설정 화면 이메일 또는 Resend 테스트 주소로 시도(403/422 시 도메인 인증 필요)
RESEND_FROM=

# --- OpenAI (AI 견적 초안·문의 구조화·발송 문구 — 선택이나 기능 사용 시 필수) ---
OPENAI_API_KEY=
# 기본 gpt-4o-mini. 운영 비용·품질에 맞게 변경 가능
OPENAI_MODEL=gpt-4o-mini
# AI HTTP 타임아웃(ms). 기본 55000
# OPENAI_TIMEOUT_MS=55000

# --- 공개 문의 이메일 (랜딩 /billing Business 블록) ---
# NEXT_PUBLIC_CONTACT_EMAIL=

# --- 데모 로그인 (선택) ---
# ENABLE_DEMO_LOGIN 동작 요약:
#   - "true" / "1"  → 어떤 NODE_ENV 에서도 데모 로그인·데모 쿠키 인정 (Supabase 설정 여부와 무관)
#   - "false" / "0" → 어떤 NODE_ENV 에서도 데모 비활성
#   - 미설정        → production 에서만 데모 끔 / 그 외(로컬 등)에서는 데모 허용
#
# 프로덕션(Vercel Production) 기본: 데모 비활성.
# 외부 점검용 공개 데모: docs/public-demo.md 참고. 켤 때 DEMO_LOGIN_PASSWORD 는 16자 이상 필수.
ENABLE_DEMO_LOGIN=

# 데모 전용(운영 계정과 다르게). 이 이메일로 Supabase Auth 사용자를 만들지 마세요.
DEMO_LOGIN_EMAIL=demo-review@flowbill.kr
# 로컬: 짧은 값 허용. 프로덕션: 16자 이상 강한 비밀번호 필수 (openssl rand -base64 24 등).
DEMO_LOGIN_PASSWORD=
